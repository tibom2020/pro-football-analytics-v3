{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/load-env.ts",
    "src/config.ts",
    "src/logger.ts",
    "src/middleware/rate-limit.ts",
    "src/routes/b365-proxy.ts",
    "src/routes/similar-matches.ts",
    "src/routes/history-save.ts",
    "src/goal-predict/rag-store.ts",
    "src/goal-predict/feature-builder.ts",
    "src/goal-predict/md-parser.ts"
  ],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
