# Sao chép file này thành `.env` trong thư mục `server/` rồi điền giá trị thật.
# `npm run dev` sẽ tự đọc `server/.env` (dotenv).

# --- Server (v3 lite) ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Thư mục lưu file .md lịch sử trận (POST /api/history/save). Mặc định: ../History từ cwd của server.
# HISTORY_EXPORT_DIR=C:/path/to/History
# Xuất .md live từ Dashboard (target=live). Mặc định: ../History_live
# HISTORY_LIVE_EXPORT_DIR=D:/WORK/LINH/pro-football-analytics-v3/History_live

# B365 — token thật chỉ đặt ở đây (server), không commit file .env
B365_API_TOKEN=your_b365_token
# Worker tùy chọn (server gọi thẳng B365 khi không cần Worker)
# B365_PROXY_URL=https://your-worker.workers.dev/

# Rate limiting (/api/* except b365-proxy)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# --- RAG / similar matches ---
# Dataset + meta (relative to server cwd when chạy `npm run dev`)
GOAL_DATASET_PATH=datasets/goal-dataset.jsonl
GOAL_DATASET_PATH_30MIN=datasets/goal-dataset-30min.jsonl
GOAL_DATASET_META_PATH=datasets/goal-dataset-meta.json
GOAL_HISTORY_DIR=History
