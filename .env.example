# Sao chép thành `.env.local` ở thư mục gốc (Vite tự nạp).

# URL server AI (local hoặc Railway/Render sau khi deploy)
VITE_AI_SERVER_URL=http://localhost:3001

# Production: bỏ Cloudflare Worker — server Node gọi thẳng B365
# VITE_B365_SKIP_WORKER=true

# Production (Vercel): token B365 chỉ đặt trên SERVER (B365_API_TOKEN), không đặt ở đây.
# VITE_B365_LOGIN_MODE=server

# Dev local (tùy chọn — tự đăng nhập, token lộ trong bundle nên chỉ dùng dev):
# VITE_B365_API_TOKEN=

# Cloudflare Worker (chỉ khi KHÔNG dùng VITE_B365_SKIP_WORKER)
# VITE_B365_PROXY_URL=https://your-worker.workers.dev/
