# PFA server origin (server/ dev). Default: http://localhost:3001
PFA_BASE_URL=http://localhost:3001

# Định danh user trong PFA — lấy từ localStorage `app_user_id` ở trình duyệt.
# DevTools → Application → Local Storage → key `app_user_id`.
PFA_USER_ID=

# (Tuỳ chọn) Override OpenHuman user_id nếu có nhiều tài khoản (hex id ở
# ~/.openhuman/users/<hex>/). Bridge tự pick folder mới nhất nếu để trống.
# OPENHUMAN_USER_ID=

# (Tuỳ chọn) Override toàn bộ vault path. Mặc định:
# bridge tự tìm `~/.openhuman/users/<active>/workspace/pfa/`.
# Đây là path mà OpenHuman có thể đọc bằng tool `file_read` (auto-approved).
# OPENHUMAN_VAULT=

# Chu kỳ poll (ms). Tối thiểu 10s, mặc định 45s.
POLL_INTERVAL_MS=45000
